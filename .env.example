CORS_ORIGINS=http://localhost:3000,http://localhost:5174
DATABASE_URL=sqlite:///./test.db
API_KEY=your-secret-key-here
FRONTEND_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PRICE_ID=price_your_price_id
STRIPE_PRICE_ID_CONTROL=price_control_optional
STRIPE_PRICE_ID_TEST=price_test_optional
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Admin auth
ADMIN_DASHBOARD_PASSWORD=change-this-owner-password
ADMIN_SESSION_SECRET=change-this-session-secret
COOKIE_SECURE=false
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_LOCKOUT_SECONDS=900

# Email reminders
RESEND_API_KEY=re_test_your_key
EMAIL_FROM=onboarding@resend.dev

